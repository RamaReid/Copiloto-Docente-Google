+  if (repeatedAuthor) {
+    if (!lastAuthor) return null;
+    const rest = parts.slice(1).join(", ").trim();
+    if (!rest) return null;
+    return {
+      citation: `${lastAuthor}, ${rest}`.replace(/\s+/g, " ").trim(),
+      carryAuthor: lastAuthor,
